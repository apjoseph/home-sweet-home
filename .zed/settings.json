{
  "languages": {
    "Markdown": {
      "language_servers": ["markdownlint"],
      "format_on_save": "off"
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "format_on_save": "off",
      "formatter": {
        "external": {
          "command": "nix",
          "arguments": ["fmt", "--"]
        }
      }
    }
  },
  "load_direnv": "shell_hook"
}
